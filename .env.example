# Ditto API credentials.
DITTO_API_TOKEN=replace-with-ditto-api-token
DITTO_WEBHOOK_SIGNING_KEY=replace-with-ditto-webhook-signing-key
ALLOW_UNSIGNED_WEBHOOKS=false
DITTO_API_BASE_URL=https://api.dittowords.com/v2

# Locale to Ditto variant developer ID mapping. Use null only for locales that should update base text.
BASE_LOCALE=ko
DITTO_LOCALE_VARIANT_IDS={"ko":"ko","en":"en","ja":"ja"}
DITTO_FORCE_VARIANT_CREATION=false

# Gemini translation provider. Inject the API key at runtime; never bake it into images.
GEMINI_API_KEY=replace-with-gemini-api-key
TRANSLATION_MODEL=gemini-3.1-flash-lite
TRANSLATION_TIMEOUT_SECONDS=10.0

# Runtime storage and retry behavior.
SQLITE_PATH=var/ditto_translation.sqlite3
WEBHOOK_TIMESTAMP_TOLERANCE_SECONDS=360
IN_PROGRESS_EVENT_TIMEOUT_SECONDS=600
OUTBOUND_UPDATE_TTL_SECONDS=1800
TRANSLATION_RETRY_ATTEMPTS=3
TRANSLATION_RETRY_INITIAL_DELAY_SECONDS=1.0
DITTO_RETRY_ATTEMPTS=3
DITTO_RETRY_INITIAL_DELAY_SECONDS=1.0
RETRY_BACKOFF_MULTIPLIER=2.0
RETRY_MAX_DELAY_SECONDS=10.0
LOG_LEVEL=INFO

# Optional Docker Compose overrides.
# DITTO_TRANSLATION_IMAGE=ghcr.io/choi138/ditto-translation:latest
# DITTO_TRANSLATION_PORT=8080
